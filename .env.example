BLACKHAWK_BASE_URL=https://your-production-blackhawk-url.example

# Codex Sites / D1 migration path.
# Hosted runtime values are managed by Sites; these placeholders are for local development and tests.
BLACKHAWK_PRIMARY_USER_ID=will-primary
BLACKHAWK_PRIMARY_USER_EMAIL=will@example.com
BLACKHAWK_AGENT_INGEST_SECRET=replace-me
BLACKHAWK_ENABLE_WORKSPACE_AGENT_INGEST=true
BLACKHAWK_BRIEF_SOURCE=supabase
BLACKHAWK_CLOUDMAILIN_FALLBACK_ACTIVE=true

NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-me
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
AGENT_SIGNALS_IMPORT_SECRET=replace-me
AGENT_RUN_REQUEST_SECRET=replace-me
ENABLE_AGENT_SIGNAL_FIXTURE_FALLBACK=false

# MeetingRecord Obsidian export sends markdown to TaskRobin by email.
RESEND_API_KEY=
TASKROBIN_EMAIL_FROM=Blackhawk <blackhawk@example.com>

# Production Microsoft 365 access uses Microsoft Graph delegated OAuth.
# Codex/ChatGPT connector plugins are development tools only and are not used at runtime.
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_TENANT_ID=organizations
MICROSOFT_GRAPH_REDIRECT_URI=https://your-production-blackhawk-url.example/api/microsoft/callback
MICROSOFT_GRAPH_SCOPES=offline_access User.Read Mail.Read Calendars.Read Chat.Read
# 32-byte key. Prefer base64:<base64-encoded-32-random-bytes>.
MICROSOFT_GRAPH_TOKEN_ENCRYPTION_KEY=
