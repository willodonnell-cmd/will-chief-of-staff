NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Required for capture (and similar) writes while using local bootstrap with no Supabase session; service role bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_SUPABASE_BOOTSTRAP_FALLBACK=
# Dev only: if HTTPS to Supabase fails with self-signed certificate in chain (e.g. corporate proxy), set true and restart next dev.
SUPABASE_DEV_ALLOW_INSECURE_TLS=
TRIGGER_SECRET_KEY=
BLACKHAWK_FORWARDING_DOMAIN=
BLACKHAWK_FORWARDING_INGEST_TOKEN=
CLOUDMAILIN_BASIC_AUTH_USERNAME=
CLOUDMAILIN_BASIC_AUTH_PASSWORD=
# Optional local/dev override for the file-backed Priority Inbox fallback store.
PRIORITY_INBOX_LOCAL_STORE_PATH=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_OUTLOOK_REDIRECT_URI=
OUTLOOK_TOKEN_ENCRYPTION_KEY=
