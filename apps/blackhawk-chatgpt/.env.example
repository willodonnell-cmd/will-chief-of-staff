# Local fictional checkpoint only. Production refuses to start in preview mode.
BLACKHAWK_AUTH_MODE=preview
HOST=127.0.0.1
PORT=8788

# Authenticated deployment:
# BLACKHAWK_AUTH_MODE=supabase
# NODE_ENV=production
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# BLACKHAWK_MCP_RESOURCE_URL=https://YOUR_BLACKHAWK_HOST/mcp
# BLACKHAWK_PRIMARY_OWNER_USER_ID=YOUR_IMMUTABLE_SUPABASE_USER_ID
# BLACKHAWK_RECOVERY_USER_IDS=OPTIONAL_COMMA_SEPARATED_RECOVERY_USER_IDS
#
# Email-only authorization is a transitional fallback. Production should use
# immutable user IDs instead.
# BLACKHAWK_ALLOWED_EMAIL=YOUR_AUTHORIZED_EMAIL
#
# The expected JWT audience defaults to BLACKHAWK_MCP_RESOURCE_URL. Only set
# BLACKHAWK_TOKEN_AUDIENCE if the authorization server has been deliberately
# configured to mint a different, Blackhawk-specific audience.
# BLACKHAWK_TOKEN_AUDIENCE=https://YOUR_BLACKHAWK_HOST/mcp
